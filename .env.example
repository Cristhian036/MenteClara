# GEMINI_API_KEY: Requerido para las llamadas a la API de IA de Gemini.
# AI Studio inyecta esto automáticamente en tiempo de ejecución desde los secretos del usuario.
# Los usuarios configuran esto a través del panel de Secretos en la interfaz de usuario de AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: La URL donde se aloja este miniapplet.
# AI Studio inyecta esto automáticamente en tiempo de ejecución con la URL del servicio Cloud Run.
# Se utiliza para enlaces autorreferenciales, devoluciones de llamada de OAuth y endpoints de API.
APP_URL="MY_APP_URL"

# VITE_API_URL: Especifica la URL del backend de Render.com (ej. https://mi-backend.onrender.com)
# al compilar el cliente para Capacitor. Déjalo vacío para un despliegue web normal.
VITE_API_URL=""

# Variables de Conexión de Base de Datos para Producción (Render.com o desarrollo local)
SQL_HOST="tu-host-de-postgres"
SQL_USER="tu-usuario-de-postgres"
SQL_PASSWORD="tu-contrasena-de-postgres"
SQL_DB_NAME="tu-nombre-de-base-de-datos-postgres"

# VITE_GOOGLE_CLIENT_ID: Identificador de cliente de Google OAuth 2.0 (opcional para login con Google)
VITE_GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
